{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net unpkg.com fonts.googleapis.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com fonts.gstatic.com; font-src fonts.gstatic.com; connect-src 'self' *.supabase.co; img-src 'self' data:; frame-ancestors 'none'"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/calendario/admin", "destination": "/calendario/admin.html" },
    { "source": "/calendario",       "destination": "/calendario/index.html" },
    { "source": "/escala",           "destination": "/escala/index.html" },
    { "source": "/abstracts",        "destination": "/abstracts/index.html" },
    { "source": "/analise-interna",  "destination": "/analise-interna/index.html" },
    { "source": "/squad-creator",    "destination": "/squad-creator/index.html" },
    { "source": "/manual-aios",      "destination": "/manual-aios/index.html" },
    { "source": "/aios-install",     "destination": "/aios-install/index.html" },
    { "source": "/alunos",           "destination": "/alunos/index.html" },
    { "source": "/api/zoom/callback","destination": "/api/zoom/callback.html" },
    { "source": "/presenca",         "destination": "/presenca/index.html" },
    { "source": "/aulas",            "destination": "/aulas/index.html" },
    { "source": "/equipe",           "destination": "/equipe/index.html" },
    { "source": "/relatorio",        "destination": "/relatorio/index.html" }
  ]
}
